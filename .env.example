# ==============================================
# Innovate Hub Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values
# For production, use .env.production or set NODE_ENV=production
# ==============================================

# Server Configuration
PORT=3000
NODE_ENV=development  # development | production

# JWT Secret - CHANGE THIS! Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Database Configuration
# Development: SQLite (zero config)
DB_TYPE=sqlite
SQLITE_DB_PATH=./database/innovate.db

# Production: PostgreSQL
# DB_TYPE=postgresql
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=innovate_hub
# PG_PASSWORD=your-strong-password
# PG_DATABASE=innovate_hub

# CORS - Allowed origins (comma-separated)
# Development: * (allow all) | Production: https://yourdomain.com
ALLOWED_ORIGINS=*

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting (defaults: 1000/15min dev, 100/15min prod)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=1000
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20

# Redis Configuration (optional in dev, recommended in prod)
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ML Service
# PYTHON_ML_SERVICE_URL=http://localhost:5000

# AI Chat API Keys
# GROQ_API_KEY=
# GOOGLE_AI_API_KEY=
# HUGGINGFACE_API_KEY=
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Ollama (local AI - supports multiple instances, comma-separated)
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URLS=http://localhost:11434,https://other-codespace-11434.app.github.dev
# OLLAMA_BASE_URL=http://localhost:11434  # single URL also works

# Logging
# LOG_LEVEL=info  # debug | info | warn | error

# Admin Account
# ADMIN_EMAIL=admin@innovatehub.com
# ADMIN_PASSWORD=your-admin-password
# ADMIN_USERNAME=admin

# Firebase Push Notifications (optional - for Android push notifications)
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
